# QuakeCore Environment Configuration
# ===================================
# Copy this file to .env and fill in your values.

# ----- LLM Configuration -----
# DeepSeek API key (required for provider=deepseek)
DEEPSEEK_API_KEY=

# LLM backend
# QUAKECORE_LLM_PROVIDER=deepseek
# QUAKECORE_LLM_MODEL=deepseek-v4-flash
# QUAKECORE_LLM_BASE_URL=

# ----- LangGraph / OpenCode Admin Post-Processing -----
# Enable LangGraph/OpenCode postprocess runtime (default: 1)
QUAKECORE_USE_LANGGRAPH=1

# OpenCode Admin replaces the old restricted analysis sandbox.
# Execution timeout for each OpenCode Admin run (seconds, default: 300)
QUAKECORE_OPENCODE_ADMIN_TIMEOUT=300

# ----- Old Analysis Sandbox (deprecated by OpenCode Admin) -----
# Allow code execution in the old restricted sandbox (default: 0)
# QUAKECORE_ANALYSIS_ALLOW_CODE=0

# ----- Python Package Index -----
# Use a custom pip index for faster package installation in admin workspace.
# PIP_INDEX_URL=https://pypi.org/simple
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
